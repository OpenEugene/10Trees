@using Microsoft.AspNetCore.Components.Forms
@using OpenEug.TenTrees.Module.Cohort.Services
@using OpenEug.TenTrees.Module.Village.Services
@using OpenEug.TenTrees.Module.Training.Services
@using OpenEug.TenTrees.Models

@namespace OpenEug.TenTrees.Module.Cohort
@inherits ModuleBase
@inject ICohortService CohortService
@inject IVillageService VillageService
@inject ITrainingService TrainingService
@inject NavigationManager NavigationManager

<div class="container">
    <div class="row justify-content-center">
        <div class="col-12 col-md-10">

            @if (!_isLoaded)
            {
                <p role="status"><em>Loading...</em></p>
            }
            else
            {
                @* ── Cohort details ──────────────────────────────────────────── *@
                <h5><span class="oi oi-layers me-2" aria-hidden="true"></span>Cohort Details</h5>

                <div class="row mb-3 align-items-center">
                    <label class="col-sm-3 col-form-label" for="village">Village</label>
                    <div class="col-sm-9">
                        <InputSelect id="village"
                                     class="@($"form-select {(_invalidFields.Contains("VillageId") ? "is-invalid" : string.Empty)}")"
                                     TValue="int"
                                     @bind-Value="_cohort.VillageId"
                                     @bind-Value:after="OnVillageChanged"
                                     aria-required="true"
                                     aria-invalid="@(_invalidFields.Contains("VillageId") ? "true" : null)"
                                     disabled="@_isEdit">
                            <option value="0">— select village —</option>
                            @foreach (var v in _villages)
                            {
                                <option value="@v.VillageId">@v.VillageName</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label class="col-sm-3 col-form-label" for="name">Name</label>
                    <div class="col-sm-9">
                        <input id="name" type="text"
                               class="form-control @(_invalidFields.Contains("Name") ? "is-invalid" : "")"
                               @bind="_cohort.Name"
                               aria-required="true"
                               aria-invalid="@(_invalidFields.Contains("Name") ? "true" : null)" />
                        @if (_suggestedName != null && _suggestedName != _cohort.Name)
                        {
                            <div class="form-text">
                                Suggested: <a href="#" @onclick="UseSuggestedName" @onclick:preventDefault>@_suggestedName</a>
                            </div>
                        }
                    </div>
                </div>

                <div class="row mb-3 align-items-center">
                    <label class="col-sm-3 col-form-label" for="status">Status</label>
                    <div class="col-sm-9">
                        <select id="status" class="form-select" @bind="_cohort.Status">
                            <option value="@CohortStatus.Planned">Planned</option>
                            <option value="@CohortStatus.Active">Active</option>
                            @if (_isEdit)
                            {
                                <option value="@CohortStatus.Completed">Completed</option>
                            }
                        </select>
                        @if (_isEdit && _originalStatus == CohortStatus.Completed)
                        {
                            <div class="form-text text-warning">Completed cohorts cannot be reactivated.</div>
                        }
                    </div>
                </div>

                <div class="d-flex gap-2 mb-4">
                    <button type="button" class="btn btn-success" @onclick="Save" disabled="@_isSaving">
                        @if (_isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                            <span>Saving...</span>
                        }
                        else
                        {
                            <span class="oi oi-check me-1" aria-hidden="true"></span>
                            <span>Save</span>
                        }
                    </button>
                    <NavLink class="btn btn-secondary" href="@NavigateUrl()">
                        <span class="oi oi-x me-1" aria-hidden="true"></span> Cancel
                    </NavLink>
                </div>

                @if (_isEdit)
                {
                    <AuditInfo CreatedBy="@_cohort.CreatedBy" CreatedOn="@_cohort.CreatedOn"
                               ModifiedBy="@_cohort.ModifiedBy" ModifiedOn="@_cohort.ModifiedOn" />

                    @* ── Grower membership ───────────────────────────────────── *@
                    <hr />
                    <h5 class="mt-4"><span class="oi oi-people me-2" aria-hidden="true"></span>Grower Members (@_growerCohorts.Count)</h5>

                    @if (_growerCohorts.Count == 0)
                    {
                        <p class="text-muted">No growers assigned to this cohort yet.</p>
                    }
                    else
                    {
                        <table class="table table-sm align-middle mb-3">
                            <thead>
                                <tr>
                                    <th>Grower ID</th>
                                    <th>Joined</th>
                                    <th><span class="visually-hidden">Actions</span></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var gc in _growerCohorts)
                                {
                                    <tr>
                                        <td>@gc.GrowerId</td>
                                        <td>@gc.JoinedOn.ToString("d MMM yyyy")</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-danger"
                                                    aria-label="@($"Remove grower {gc.GrowerId} from cohort")"
                                                    @onclick="@(async () => await RemoveGrower(gc.GrowerId))">
                                                <span class="oi oi-minus" aria-hidden="true"></span>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                    @* ── Mentor assignment ───────────────────────────────────── *@
                    <hr />
                    <h5 class="mt-4"><span class="oi oi-person me-2" aria-hidden="true"></span>Assigned Mentors (@_mentorCohorts.Count)</h5>

                    @if (_mentorCohorts.Count == 0)
                    {
                        <p class="text-muted">No mentors assigned to this cohort yet.</p>
                    }
                    else
                    {
                        <table class="table table-sm align-middle mb-3">
                            <thead>
                                <tr>
                                    <th>Mentor ID</th>
                                    <th>Assigned</th>
                                    <th><span class="visually-hidden">Actions</span></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var mc in _mentorCohorts)
                                {
                                    <tr>
                                        <td>@mc.MentorId</td>
                                        <td>@mc.AssignedOn.ToString("d MMM yyyy")</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-danger"
                                                    aria-label="@($"Remove mentor {mc.MentorId} from cohort")"
                                                    @onclick="@(async () => await RemoveMentor(mc.MentorId))">
                                                <span class="oi oi-minus" aria-hidden="true"></span>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                    @* ── Class association ──────────────────────────────────── *@
                    <hr />
                    <h5 class="mt-4"><span class="oi oi-book me-2" aria-hidden="true"></span>Linked Classes (@_cohortClasses.Count)</h5>

                    @if (_availableClasses.Count > 0)
                    {
                        <div class="d-flex gap-2 align-items-center mb-2">
                            <label class="form-label mb-0" for="classToAdd">Add class:</label>
                            <select id="classToAdd" class="form-select form-select-sm" style="width: auto;" @bind="_classToAdd">
                                <option value="0">— select —</option>
                                @foreach (var c in _availableClasses)
                                {
                                    <option value="@c.TrainingClassId">@c.ClassName (@c.ClassDate.ToString("d MMM yyyy"))</option>
                                }
                            </select>
                            <button class="btn btn-sm btn-outline-primary" @onclick="AddClass"
                                    disabled="@(_classToAdd == 0)">
                                <span class="oi oi-plus" aria-hidden="true"></span> Add
                            </button>
                        </div>
                    }

                    @if (_cohortClasses.Count == 0)
                    {
                        <p class="text-muted">No classes linked to this cohort.</p>
                    }
                    else
                    {
                        <table class="table table-sm align-middle mb-3">
                            <thead>
                                <tr>
                                    <th>Class Name</th>
                                    <th>Date</th>
                                    <th><span class="visually-hidden">Actions</span></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cc in _cohortClasses)
                                {
                                    var cls = _allClasses.FirstOrDefault(c => c.TrainingClassId == cc.TrainingClassId);
                                    <tr>
                                        <td>@(cls?.ClassName ?? $"Class {cc.TrainingClassId}")</td>
                                        <td>@(cls?.ClassDate.ToString("d MMM yyyy") ?? "—")</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-danger"
                                                    aria-label="@($"Remove class {cls?.ClassName ?? cc.TrainingClassId.ToString()} from cohort")"
                                                    @onclick="@(async () => await RemoveClass(cc.TrainingClassId))">
                                                <span class="oi oi-minus" aria-hidden="true"></span>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                }
            }
        </div>
    </div>
</div>

@code {
    public override string Actions => "Add,Edit";
    public override string Title => "Manage Cohort";
    public override SecurityAccessLevel SecurityAccessLevel => SecurityAccessLevel.Admin;
    public override bool UseAdminContainer => false;

    private bool _isLoaded;
    private bool _isEdit;
    private bool _isSaving;
    private HashSet<string> _invalidFields = new();

    private Cohort _cohort = new() { Status = CohortStatus.Planned };
    private CohortStatus _originalStatus;
    private List<Village> _villages = new();
    private string _suggestedName;

    private List<GrowerCohort> _growerCohorts = new();
    private List<MentorCohort> _mentorCohorts = new();
    private List<CohortClass> _cohortClasses = new();
    private List<TrainingClass> _allClasses = new();
    private List<TrainingClass> _availableClasses = new();
    private int _classToAdd;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            _villages = await VillageService.GetActiveVillagesAsync();

            if (PageState.Action == "Edit")
            {
                _isEdit = true;
                int cohortId = int.Parse(PageState.QueryString["id"]);
                _cohort = await CohortService.GetCohortAsync(cohortId);
                _originalStatus = _cohort.Status;
                _growerCohorts = await CohortService.GetGrowerCohortsAsync(cohortId);
                _mentorCohorts = await CohortService.GetMentorCohortsAsync(cohortId);
                _cohortClasses = await CohortService.GetClassesForCohortAsync(cohortId);
                await LoadAvailableClassesAsync();
            }
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Loading Cohort {Error}", ex.Message);
            AddModuleMessage("Unable to load cohort.", MessageType.Error);
        }
        finally
        {
            _isLoaded = true;
        }
    }

    private async Task OnVillageChanged()
    {
        if (_cohort.VillageId <= 0)
        {
            _suggestedName = null;
            return;
        }

        if (!_isEdit)
        {
            try
            {
                _suggestedName = await CohortService.GetSuggestedNameAsync(_cohort.VillageId, DateTime.UtcNow.Year);
                _cohort.Name = _suggestedName;
                StateHasChanged();
            }
            catch (Exception ex)
            {
                await logger.LogError(ex, "Error generating suggested cohort name {Error}", ex.Message);
            }
        }
    }

    private void UseSuggestedName() => _cohort.Name = _suggestedName;

    private async Task Save()
    {
        ClearModuleMessage();
        _invalidFields.Clear();

        _cohort.Name = _cohort.Name?.Trim();

        var missing = new List<string>();
        if (_cohort.VillageId == 0) { _invalidFields.Add("VillageId"); missing.Add("Village"); }
        if (string.IsNullOrWhiteSpace(_cohort.Name)) { _invalidFields.Add("Name"); missing.Add("Name"); }

        if (missing.Count > 0)
        {
            AddModuleMessage($"Required: {string.Join(", ", missing)}", MessageType.Warning);
            await ScrollToPageTop();
            return;
        }

        var allCohorts = await CohortService.GetCohortsAsync();
        var duplicateExists = allCohorts.Any(c =>
            c.CohortId != _cohort.CohortId &&
            string.Equals(c.Name?.Trim(), _cohort.Name, StringComparison.OrdinalIgnoreCase));

        if (duplicateExists)
        {
            _invalidFields.Add("Name");
            AddModuleMessage("Cohort name must be unique.", MessageType.Warning);
            await ScrollToPageTop();
            return;
        }

        // Guard: completed cohorts cannot be reverted
        if (_isEdit && _originalStatus == CohortStatus.Completed && _cohort.Status != CohortStatus.Completed)
        {
            AddModuleMessage("A completed cohort cannot be reactivated.", MessageType.Warning);
            _cohort.Status = CohortStatus.Completed;
            return;
        }

        _isSaving = true;
        try
        {
            if (_isEdit)
            {
                await CohortService.UpdateCohortAsync(_cohort);
                await logger.LogInformation("Cohort Updated {Cohort}", _cohort.Name);
            }
            else
            {
                await CohortService.AddCohortAsync(_cohort);
                await logger.LogInformation("Cohort Added {Cohort}", _cohort.Name);
            }
            NavigationManager.NavigateTo(NavigateUrl());
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Saving Cohort {Cohort} {Error}", _cohort.Name, ex.Message);
            AddModuleMessage("Unable to save cohort.", MessageType.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task RemoveGrower(int growerId)
    {
        try
        {
            await CohortService.RemoveGrowerFromCohortAsync(_cohort.CohortId, growerId);
            _growerCohorts = await CohortService.GetGrowerCohortsAsync(_cohort.CohortId);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Removing Grower {GrowerId} from Cohort {Error}", growerId, ex.Message);
            AddModuleMessage("Unable to remove grower.", MessageType.Error);
        }
    }

    private async Task RemoveMentor(string mentorId)
    {
        try
        {
            await CohortService.RemoveMentorFromCohortAsync(_cohort.CohortId, mentorId);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Removing Mentor {MentorId} from Cohort {Error}", mentorId, ex.Message);
            AddModuleMessage("Unable to remove mentor.", MessageType.Error);
        }
    }

    private async Task LoadAvailableClassesAsync()
    {
        _allClasses = await TrainingService.GetTrainingClassesAsync(ModuleState.ModuleId,
            _cohort.VillageId > 0 ? _cohort.VillageId : null);
        var linked = _cohortClasses.Select(cc => cc.TrainingClassId).ToHashSet();
        _availableClasses = _allClasses.Where(c => !linked.Contains(c.TrainingClassId))
            .OrderByDescending(c => c.ClassDate).ToList();
    }

    private async Task AddClass()
    {
        if (_classToAdd == 0) return;
        try
        {
            await CohortService.AddCohortClassAsync(_cohort.CohortId, _classToAdd);
            _cohortClasses = await CohortService.GetClassesForCohortAsync(_cohort.CohortId);
            _classToAdd = 0;
            await LoadAvailableClassesAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Adding Class {ClassId} to Cohort {Error}", _classToAdd, ex.Message);
            AddModuleMessage("Unable to add class.", MessageType.Error);
        }
    }

    private async Task RemoveClass(int trainingClassId)
    {
        try
        {
            await CohortService.RemoveCohortClassAsync(_cohort.CohortId, trainingClassId);
            _cohortClasses = await CohortService.GetClassesForCohortAsync(_cohort.CohortId);
            await LoadAvailableClassesAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Removing Class {ClassId} from Cohort {Error}", trainingClassId, ex.Message);
            AddModuleMessage("Unable to remove class.", MessageType.Error);
        }
    }

}
