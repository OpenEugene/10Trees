@using Oqtane.Modules.Controls
@using OpenEug.TenTrees.Module.Training.Services
@using OpenEug.TenTrees.Module.Village.Services
@using OpenEug.TenTrees.Module.Cohort.Services
@using OpenEug.TenTrees.Models
@using Oqtane.UI

@namespace OpenEug.TenTrees.Module.Training
@inherits ModuleBase
@inject ITrainingService TrainingService
@inject IVillageService VillageService
@inject ICohortService CohortService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Edit> Localizer
@inject IJSRuntime JSRuntime

<form @ref="form" class="@(validated ? " was-validated" : "needs-validation" )" novalidate>
    <div class="container">
        <h3>@(_id > 0 ? Localizer["Title.EditSession"] : Localizer["Title.AddSession"])</h3>

        <div class="card mb-3">
            <div class="card-header">
                <h5>@Localizer["Section.SessionDetails"]</h5>
            </div>
            <div class="card-body">
                <div class="row mb-2">
                    <Label Class="col-sm-4" For="classname" ResourceKey="ClassName">Class Name:</Label>
                    <div class="col-sm-8">
                        <input id="classname" class="form-control" @bind="@_className" required />
                    </div>
                </div>
                <div class="row mb-2">
                    <Label Class="col-sm-4" For="classdate" ResourceKey="ClassDate">Date:</Label>
                    <div class="col-sm-8">
                        <input id="classdate" type="date" class="form-control" @bind="@_classDate" required />
                    </div>
                </div>
                <div class="row mb-2">
                    <Label Class="col-sm-4" For="villageid" ResourceKey="Village">Village:</Label>
                    <div class="col-sm-8">
                        <select id="villageid" class="form-select" @bind="@_villageId" required>
                            <option value="0">@Localizer["SelectVillage"]</option>
                            @if (_villages != null)
                            {
                                @foreach (var village in _villages)
                                {
                                    <option value="@village.VillageId">@village.VillageName</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="row mb-2">
                    <Label Class="col-sm-4" For="classnumber" ResourceKey="ClassNumber">Class Number (1-5):</Label>
                    <div class="col-sm-8">
                        <select id="classnumber" class="form-select" @bind="@_classNumber" required>
                            <option value="0">@Localizer["SelectClassNumber"]</option>
                            @for (int i = 1; i <= 5; i++)
                            {
                                <option value="@i">@i</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="row mb-2">
                    <Label Class="col-sm-4" For="notes" ResourceKey="Notes">Notes:</Label>
                    <div class="col-sm-8">
                        <textarea id="notes" class="form-control" rows="3" @bind="@_notes"></textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="button" class="btn btn-success" @onclick="Save">@Localizer["Action.Save"]</button>
            <button type="button" class="btn btn-secondary" @onclick="Cancel">@Localizer["Action.Cancel"]</button>
        </div>

        @if (_id > 0)
        {
            <hr class="mt-4" />
            <h5 class="mt-3"><span class="oi oi-layers me-2" aria-hidden="true"></span>Linked Cohorts</h5>

            <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                @foreach (var cc in _linkedCohorts)
                {
                    var coh = _allCohorts.FirstOrDefault(c => c.CohortId == cc.CohortId);
                    var name = coh?.Name ?? $"Cohort {cc.CohortId}";

                    @if (_pendingRemoveCohortId == cc.CohortId)
                    {
                        <span class="badge bg-warning text-dark d-inline-flex align-items-center gap-1 py-2 px-2">
                            Remove <strong>@name</strong>?
                            <button class="btn btn-sm btn-warning border-0 py-0 px-1 fw-bold"
                                    aria-label="Confirm remove @name"
                                    @onclick="@(async () => await RemoveCohort(cc.CohortId))">Yes</button>
                            <button class="btn btn-sm btn-outline-secondary border-0 py-0 px-1"
                                    aria-label="Cancel remove @name"
                                    @onclick="@(() => _pendingRemoveCohortId = 0)">No</button>
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-primary d-inline-flex align-items-center gap-1 py-2 px-2">
                            @name
                            <button class="btn-close btn-close-white ms-1"
                                    style="font-size:0.55em;"
                                    aria-label="@($"Remove cohort {name}")"
                                    @onclick="@(() => _pendingRemoveCohortId = cc.CohortId)"></button>
                        </span>
                    }
                }

                @if (_availableCohorts.Count > 0)
                {
                    <select class="form-select form-select-sm d-inline-block w-auto"
                            aria-label="Add cohort"
                            @bind="_cohortToAdd" @bind:after="AddCohort">
                        <option value="0">+ Add cohort…</option>
                        @foreach (var c in _availableCohorts)
                        {
                            <option value="@c.CohortId">@c.Name</option>
                        }
                    </select>
                }

                @if (_linkedCohorts.Count == 0 && _availableCohorts.Count == 0)
                {
                    <span class="text-muted small">No cohorts available.</span>
                }
            </div>
        }
    </div>
</form>

@code {
    public override SecurityAccessLevel SecurityAccessLevel => SecurityAccessLevel.Edit;

    private ElementReference form;
    private bool validated = false;

    private int _id;
    private string _className = "";
    private DateTime _classDate = DateTime.Today;
    private int _villageId;
    private int _classNumber;
    private string _notes = "";
    private List<Models.Village> _villages;

    private List<Models.CohortClass> _linkedCohorts = new();
    private List<Models.Cohort> _allCohorts = new();
    private List<Models.Cohort> _availableCohorts = new();
    private int _cohortToAdd;
    private int _pendingRemoveCohortId;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            var isEditAction = PageState.Action == "Edit";
            int trainingClassId = 0;
            var hasId = PageState.QueryString.ContainsKey("id") && int.TryParse(PageState.QueryString["id"], out trainingClassId);

            _villages = await VillageService.GetVillagesAsync();

            if (isEditAction && hasId)
            {
                _id = trainingClassId;
                var trainingClass = await TrainingService.GetTrainingClassAsync(_id, ModuleState.ModuleId);
                if (trainingClass != null)
                {
                    _className = trainingClass.ClassName;
                    _classDate = trainingClass.ClassDate;
                    _villageId = trainingClass.VillageId;
                    _classNumber = trainingClass.ClassNumber;
                    _notes = trainingClass.Notes ?? "";
                }
                _linkedCohorts = await CohortService.GetCohortsForClassAsync(_id);
                _allCohorts = await CohortService.GetCohortsAsync();
                await RefreshAvailableCohortsAsync();
            }
            else
            {
                _id = 0;
            }
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Loading Training Class {Error}", ex.Message);
            AddModuleMessage(Localizer["Message.LoadError"], MessageType.Error);
        }
    }

    private async Task Save()
    {
        validated = true;
        var interop = new Interop(JSRuntime);

        if (await interop.FormValid(form))
        {
            try
            {
                if (_id > 0)
                {
                    var trainingClass = await TrainingService.GetTrainingClassAsync(_id, ModuleState.ModuleId);
                    trainingClass.ClassName = _className;
                    trainingClass.ClassDate = _classDate;
                    trainingClass.VillageId = _villageId;
                    trainingClass.ClassNumber = _classNumber;
                    trainingClass.Notes = _notes;
                    await TrainingService.UpdateTrainingClassAsync(trainingClass);
                    await logger.LogInformation("Training Class Updated {ClassName}", _className);
                }
                else
                {
                    var trainingClass = new TrainingClass
                    {
                        ModuleId = ModuleState.ModuleId,
                        ClassName = _className,
                        ClassDate = _classDate,
                        VillageId = _villageId,
                        ClassNumber = _classNumber,
                        Notes = _notes
                    };
                    await TrainingService.AddTrainingClassAsync(trainingClass);
                    await logger.LogInformation("Training Class Added {ClassName}", _className);
                }

                NavigationManager.NavigateTo(NavigateUrl());
            }
            catch (Exception ex)
            {
                await logger.LogError(ex, "Error Saving Training Class {Error}", ex.Message);
                AddModuleMessage(Localizer["Message.SaveError"], MessageType.Error);
            }
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo(NavigateUrl());
    }

    private Task RefreshAvailableCohortsAsync()
    {
        var linked = _linkedCohorts.Select(cc => cc.CohortId).ToHashSet();
        _availableCohorts = _allCohorts
            .Where(c => !linked.Contains(c.CohortId) && c.Status != Models.CohortStatus.Completed)
            .OrderBy(c => c.Name).ToList();
        return Task.CompletedTask;
    }

    private async Task AddCohort()
    {
        if (_cohortToAdd == 0 || _id == 0) return;
        try
        {
            await CohortService.AddCohortClassAsync(_cohortToAdd, _id);
            _linkedCohorts = await CohortService.GetCohortsForClassAsync(_id);
            _cohortToAdd = 0;
            _pendingRemoveCohortId = 0;
            await RefreshAvailableCohortsAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Linking Cohort {CohortId} to Class {ClassId}. Error: {Error}", _cohortToAdd, _id, ex.Message);
            AddModuleMessage(Localizer["Message.SaveError"], MessageType.Error);
        }
    }

    private async Task RemoveCohort(int cohortId)
    {
        try
        {
            await CohortService.RemoveCohortClassAsync(cohortId, _id);
            _linkedCohorts = await CohortService.GetCohortsForClassAsync(_id);
            _pendingRemoveCohortId = 0;
            await RefreshAvailableCohortsAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Unlinking Cohort {CohortId} from Class {ClassId}. Error: {Error}", cohortId, _id, ex.Message);
            AddModuleMessage(Localizer["Message.SaveError"], MessageType.Error);
        }
    }
}
